#!/usr/bin/env bash

set -euo pipefail

DOTFILES_CONFIG="$HOME/.dotfiles/misc/ghostty/config"
TARGET_DIR="$HOME/.config/ghostty"
TARGET_FILE="$TARGET_DIR/config"

mkdir -p "$TARGET_DIR"

if [ -L "$TARGET_FILE" ] && [ "$(readlink "$TARGET_FILE")" = "$DOTFILES_CONFIG" ]; then
  echo "Already linked: $TARGET_FILE -> $DOTFILES_CONFIG"
  exit 0
fi

if [ -L "$TARGET_FILE" ]; then
  rm "$TARGET_FILE"
elif [ -e "$TARGET_FILE" ]; then
  backup="$TARGET_FILE.pre-dotfiles-$(date +%Y%m%d%H%M%S)"
  mv "$TARGET_FILE" "$backup"
  echo "Backed up existing ghostty config to $backup"
fi

ln -s "$DOTFILES_CONFIG" "$TARGET_FILE"
echo "Linked $TARGET_FILE -> $DOTFILES_CONFIG"
