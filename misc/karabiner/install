#!/usr/bin/env bash

set -euo pipefail

DOTFILES_DIR="$HOME/.dotfiles/misc/karabiner"
TARGET_DIR="$HOME/.config/karabiner"

# Prefer directory-level symlink — Karabiner uses atomic writes (rename),
# which would replace a file-level symlink with a real file on every save.
if [ -L "$TARGET_DIR" ] && [ "$(readlink "$TARGET_DIR")" = "$DOTFILES_DIR" ]; then
  echo "Already linked: $TARGET_DIR -> $DOTFILES_DIR"
  exit 0
fi

if [ -L "$TARGET_DIR" ]; then
  rm "$TARGET_DIR"
elif [ -e "$TARGET_DIR" ]; then
  backup="$TARGET_DIR.pre-dotfiles-$(date +%Y%m%d%H%M%S)"
  mv "$TARGET_DIR" "$backup"
  echo "Backed up existing karabiner dir to $backup"
fi

ln -s "$DOTFILES_DIR" "$TARGET_DIR"
echo "Linked $TARGET_DIR -> $DOTFILES_DIR"
