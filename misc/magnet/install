#!/usr/bin/env bash

set -euo pipefail

SOURCE_PLIST="$HOME/.dotfiles/misc/magnet/com.crowdcafe.windowmagnet.plist"
TARGET_PLIST="$HOME/Library/Preferences/com.crowdcafe.windowmagnet.plist"

mkdir -p "$(dirname "$TARGET_PLIST")"

if [ ! -f "$SOURCE_PLIST" ]; then
  echo "Missing source plist: $SOURCE_PLIST" >&2
  exit 1
fi

if [ -L "$TARGET_PLIST" ]; then
  rm "$TARGET_PLIST"
elif [ -e "$TARGET_PLIST" ]; then
  backup="$TARGET_PLIST.pre-dotfiles-$(date +%Y%m%d%H%M%S)"
  mv "$TARGET_PLIST" "$backup"
  echo "Backed up existing Magnet plist to $backup"
fi

ln -s "$SOURCE_PLIST" "$TARGET_PLIST"
echo "Linked $TARGET_PLIST -> $SOURCE_PLIST"
